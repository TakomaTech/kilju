import "json"

~(mut) users = null

fnc buildUserArray() start
    json > array(
        json > object_(id: 1, name: "Alice", role: "admin"),
        json > object_(id: 2, name: "Bob", role: "user"),
        json > object_(id: 3, name: "Charlie", role: "user")
    ) into users
end fnc

buildUserArray()
json > stringify(users) into output
format output
