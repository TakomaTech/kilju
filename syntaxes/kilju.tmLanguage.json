{
  "scopeName": "source.kilju",
  "name": "Kilju",
  "patterns": [
    {
      "name": "comment.line.number-sign.kilju",
      "match": "#.*$"
    },
    {
      "name": "keyword.control.kilju",
      "match": "\\b(?:format|import|fnc|start|loop|end|if|else|while|into|null|mut)\\b"
    },
    {
      "name": "constant.numeric.kilju",
      "match": "\\b\\d+(?:\\.\\d+)?\\b"
    },
    {
      "name": "string.quoted.double.kilju",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.kilju",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "entity.name.function.kilju",
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\s*(?=\\()"
    },
    {
      "name": "variable.other.kilju",
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
    },
    {
      "name": "keyword.operator.kilju",
      "match": "==|!=|<=|>=|[+\\-*/%=>]"
    },
    {
      "name": "punctuation.separator.kilju",
      "match": "[(),~]"
    }
  ],
  "repository": {}
}
